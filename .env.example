# Last.fm API credentials (required)
# Get these from https://www.last.fm/api/account/create
LASTFM_API_KEY=
LASTFM_API_SECRET=

# Last.fm authentication (provide session key OR username + password hash)
LASTFM_SESSION_KEY=
LASTFM_USERNAME=
LASTFM_PASSWORD_HASH=

# Sonos speaker filter (optional, comma-separated speaker names)
# Leave empty to scrobble from all speakers
SONOS_SPEAKERS=

# Web UI port (default: 8080)
WEB_PORT=8080

# Logging level (default: INFO)
LOG_LEVEL=INFO
